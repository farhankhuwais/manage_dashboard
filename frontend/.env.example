DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
JWT_SECRET="ganti-dengan-secret-anda-yang-panjang-dan-acak-min-32-karakter"

# Password awal akun admin (hanya dipakai oleh /api/setup di luar production).
